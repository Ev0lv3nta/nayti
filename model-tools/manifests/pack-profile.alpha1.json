{
  "schemaVersion": 1,
  "packId": "nayti-offline-search",
  "packVersion": "0.1.0-alpha.1",
  "compatibility": {
    "minAppVersionCode": 1,
    "maxAppVersionCode": 1,
    "engineApi": 1,
    "minAndroidApi": 30,
    "abis": [
      "arm64-v8a"
    ],
    "pageSizes": [
      4096,
      16384
    ]
  },
  "runtime": {
    "format": "ORT",
    "onnxRuntime": "1.27.0",
    "onnxRuntimeExtensions": "0.15.0+fe4e13f",
    "executionProvider": "CPU",
    "targetPlatform": "arm",
    "operatorConfigPath": "operators/required-operators.config"
  },
  "components": [
    {
      "componentId": "siglip2-image",
      "artifactPath": "models/siglip2_image.ort",
      "sourceComponent": "siglip2-base-patch16-256",
      "sourceRevision": "3f9f96cb90da5dbc758b01813f2f6f1aee24c1ab",
      "license": "Apache-2.0",
      "precision": "FP32",
      "inputs": {
        "pixel_values": {
          "dtype": "float32",
          "shape": [1, 3, 256, 256],
          "color": "RGB",
          "range": [-1, 1]
        }
      },
      "outputs": {
        "image_embedding": {
          "dtype": "float32",
          "shape": [1, 768],
          "normalization": "L2"
        }
      }
    },
    {
      "componentId": "siglip2-text",
      "artifactPath": "models/siglip2_text.ort",
      "sourceComponent": "siglip2-base-patch16-256",
      "sourceRevision": "3f9f96cb90da5dbc758b01813f2f6f1aee24c1ab",
      "license": "Apache-2.0",
      "precision": "FP32-transformer-rowwise-QInt8-token-embedding",
      "inputs": {
        "input_ids": {
          "dtype": "int64",
          "shape": [1, 64]
        }
      },
      "outputs": {
        "text_embedding": {
          "dtype": "float32",
          "shape": [1, 768],
          "normalization": "L2"
        }
      }
    },
    {
      "componentId": "siglip2-tokenizer",
      "artifactPath": "models/siglip2_tokenizer.ort",
      "sourceComponent": "siglip2-base-patch16-256",
      "sourceRevision": "3f9f96cb90da5dbc758b01813f2f6f1aee24c1ab",
      "license": "Apache-2.0",
      "maxLength": 64,
      "customOperator": "HfJsonTokenizer"
    },
    {
      "componentId": "user2-encoder",
      "artifactPath": "models/user2_encoder.ort",
      "sourceComponent": "user2-small",
      "sourceRevision": "23f65b34cf7632032061f5cc66c14714e6d4cee4",
      "license": "Apache-2.0",
      "precision": "dynamic-per-channel-QInt8-rowwise-QInt8-token-embedding",
      "inputs": {
        "input_ids": {
          "dtype": "int64",
          "shape": [1, 128]
        },
        "attention_mask": {
          "dtype": "int64",
          "shape": [1, 128]
        }
      },
      "outputs": {
        "sentence_embedding": {
          "dtype": "float32",
          "shape": [1, 384],
          "normalization": "L2"
        }
      }
    },
    {
      "componentId": "user2-tokenizer",
      "artifactPath": "models/user2_tokenizer.ort",
      "sourceComponent": "user2-small",
      "sourceRevision": "23f65b34cf7632032061f5cc66c14714e6d4cee4",
      "license": "Apache-2.0",
      "maxLength": 128,
      "customOperator": "HfJsonTokenizer"
    },
    {
      "componentId": "ppocrv6-detector",
      "artifactPath": "models/ppocrv6_detector.ort",
      "sourceComponent": "ppocrv6-small-det-onnx",
      "sourceRevision": "28fe5895c24fd108c19eb3e8479f4ab385fbfc62",
      "license": "Apache-2.0",
      "precision": "FP32",
      "contractPath": "contracts/ocr.json"
    },
    {
      "componentId": "eslav-recognizer",
      "artifactPath": "models/eslav_recognizer.ort",
      "sourceComponent": "eslav-ppocrv5-mobile-rec-onnx",
      "sourceRevision": "9a32171fc5718746875e1a261818884517975013",
      "license": "Apache-2.0",
      "precision": "FP32",
      "contractPath": "contracts/ocr.json"
    }
  ],
